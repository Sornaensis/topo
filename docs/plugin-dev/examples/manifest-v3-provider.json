{
  "manifestVersion": 3,
  "name": "civilization",
  "version": "1.0.0",
  "runtime": {
    "protocol": { "min": 4, "max": 4 },
    "topo": { "min": "1.0" }
  },
  "description": "Civilization simulation overlay and settlement catalogue",
  "ui": {
    "displayName": "Civilization",
    "category": "Simulation",
    "tags": ["settlements", "culture"]
  },
  "generator": {
    "insertAfter": "biomes",
    "requires": ["biomes", "rivers"]
  },
  "simulation": {
    "dependencies": ["weather"],
    "interval_ticks": 1,
    "phase_ticks": 0,
    "catch_up": "run_once_if_due"
  },
  "invocationScopes": {
    "version": 1,
    "generator": {
      "input": {
        "terrainSections": ["terrain", "climate", "vegetation"],
        "chunks": { "type": "all" },
        "dependencyOverlays": [],
        "ownOverlay": false
      },
      "output": {
        "terrainSections": ["terrain", "climate", "vegetation"],
        "chunks": { "type": "all" },
        "ownedOverlay": true,
        "generatorMetadata": true
      },
      "budgets": { "terrainBytes": 67108864, "overlayBytes": 67108864, "outputBytes": 67108864 }
    },
    "simulation": {
      "input": {
        "terrainSections": ["terrain", "climate", "vegetation"],
        "chunks": { "type": "all" },
        "dependencyOverlays": ["weather"],
        "ownOverlay": true
      },
      "output": {
        "terrainSections": ["terrain", "climate", "vegetation"],
        "chunks": { "type": "all" },
        "ownedOverlay": true,
        "generatorMetadata": false
      },
      "budgets": { "terrainBytes": 67108864, "overlayBytes": 67108864, "outputBytes": 67108864 }
    }
  },
  "overlay": {
    "schemaFile": "civilization.toposchema"
  },
  "capabilities": ["readTerrain", "readOverlay", "writeOverlay", "dataRead", "log"],
  "config": {
    "parameters": [
      {
        "name": "growth_rate",
        "label": "Growth Rate",
        "type": "float",
        "default": 0.02,
        "range": [0.0, 0.5],
        "tooltip": "Population growth fraction per tick"
      }
    ]
  },
  "dataResources": [
    {
      "schemaVersion": 1,
      "resourceVersion": 1,
      "name": "settlements",
      "label": "Settlements",
      "hexBound": true,
      "fields": [
        { "name": "id", "type": "text", "label": "Settlement ID" },
        { "name": "population", "type": "int", "label": "Population" }
      ],
      "operations": {
        "list": true,
        "get": true,
        "create": false,
        "update": false,
        "delete": false,
        "queryByHex": true,
        "queryByField": false,
        "sort": false,
        "filter": false,
        "page": false
      },
      "keyField": "id",
      "pagination": {
        "defaultPageSize": 20,
        "maxPageSize": 500,
        "defaultPageOffset": 0
      }
    }
  ],
  "externalDataSources": [
    {
      "name": "settlement-ledger",
      "label": "Settlement Ledger",
      "description": "Provider-owned settlement records shared with dependent plugins",
      "kind": "catalog",
      "capabilities": ["query", "health"],
      "resources": ["settlements"],
      "status": {
        "state": "ready",
        "message": "Records are available through the provider plugin",
        "providerId": "civilization",
        "availability": "available",
        "health": "healthy",
        "accessMode": "read_only",
        "capabilityScope": ["query", "health"],
        "version": "settlement-ledger.v1",
        "compatibility": "manifest-v3",
        "diagnostics": {
          "reportedBy": "civilization"
        }
      },
      "connection": {
        "handle": "provider-owned:settlement-ledger"
      },
      "configRefs": [
        {
          "name": "settlement-ledger-binding",
          "origin": "provider",
          "key": "civilization.settlement-ledger",
          "required": true,
          "compatibility": "manifest-v3",
          "metadata": {
            "handle": "provider-owned:settlement-ledger"
          }
        }
      ],
      "grants": [
        {
          "name": "settlement-read",
          "access": ["read"],
          "capabilities": ["query", "health"],
          "resources": ["settlements"],
          "status": {
            "state": "ready",
            "message": "Read grant can be brokered to dependent plugins",
            "providerId": "civilization",
            "availability": "available",
            "health": "healthy",
            "accessMode": "read_only",
            "capabilityScope": ["query", "health"],
            "version": "settlement-read.v1",
            "compatibility": "manifest-v3",
            "diagnostics": {
              "grant": "settlement-read"
            }
          },
          "reference": {
            "handle": "grant:settlement-read"
          },
          "configRefs": [
            {
              "name": "settlement-read-binding",
              "origin": "provider",
              "key": "civilization.settlement-read",
              "required": true,
              "compatibility": "manifest-v3",
              "metadata": {
                "grant": "settlement-read"
              }
            }
          ]
        }
      ],
      "ui": {
        "displayName": "Settlement Ledger",
        "category": "External data"
      }
    }
  ]
}
