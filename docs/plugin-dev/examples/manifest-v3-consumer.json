{
  "manifestVersion": 3,
  "name": "trade-routes",
  "version": "0.3.0",
  "runtime": {
    "protocol": { "min": 4, "max": 4 }
  },
  "description": "Trade route simulation that consumes settlement data",
  "ui": {
    "displayName": "Trade Routes",
    "category": "Simulation",
    "tags": ["trade", "settlements"]
  },
  "generator": {
    "insertAfter": "civilization",
    "requires": ["civilization"]
  },
  "invocationScopes": {
    "version": 1,
    "generator": {
      "input": {
        "terrainSections": ["terrain", "climate", "vegetation"],
        "chunks": { "type": "all" },
        "dependencyOverlays": [],
        "ownOverlay": false
      },
      "output": {
        "terrainSections": ["terrain", "climate", "vegetation"],
        "chunks": { "type": "all" },
        "ownedOverlay": false,
        "generatorMetadata": false
      },
      "budgets": { "terrainBytes": 67108864, "overlayBytes": 67108864, "outputBytes": 67108864 }
    }
  },
  "capabilities": ["readTerrain", "dataRead", "log"],
  "externalDataSourceRefs": [
    {
      "name": "settlements",
      "provider": "civilization",
      "source": "settlement-ledger",
      "required": true,
      "access": ["read"],
      "resources": ["settlements"],
      "grant": "settlement-read",
      "status": {
        "state": "unknown",
        "message": "Resolved during plugin dependency startup",
        "providerId": "civilization",
        "availability": "unknown",
        "health": "unknown",
        "accessMode": "read_only",
        "capabilityScope": ["query"],
        "version": "settlement-ledger.v1",
        "compatibility": "manifest-v3",
        "diagnostics": {
          "resolution": "dependency-startup"
        }
      },
      "reference": {
        "binding": "trade-routes:settlements"
      },
      "configRefs": [
        {
          "name": "settlements-binding",
          "origin": "deployment",
          "key": "trade-routes.settlements",
          "required": true,
          "compatibility": "manifest-v3",
          "metadata": {
            "binding": "trade-routes:settlements"
          }
        }
      ]
    }
  ]
}
