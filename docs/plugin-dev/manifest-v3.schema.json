{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://topo.dev/schemas/plugin-manifest-v3.schema.json",
  "title": "Topo plugin manifest v3",
  "type": "object",
  "required": ["manifestVersion", "name", "version", "runtime"],
  "properties": {
    "manifestVersion": { "const": 3 },
    "name": { "type": "string" },
    "version": { "type": "string" },
    "runtime": { "$ref": "#/$defs/runtime" },
    "description": { "type": "string" },
    "ui": { "$ref": "#/$defs/uiHints" },
    "generator": { "$ref": "#/$defs/generator" },
    "simulation": { "$ref": "#/$defs/simulation" },
    "invocationScopes": { "$ref": "#/$defs/invocationScopes" },
    "overlay": { "$ref": "#/$defs/overlay" },
    "capabilities": { "type": "array", "items": { "type": "string", "enum": ["log", "noise", "readTerrain", "writeTerrain", "readOverlay", "writeOverlay", "readWorld", "writeWorld", "dataRead", "dataWrite"] } },
    "config": { "$ref": "#/$defs/config" },
    "dataResources": { "type": "array", "items": { "$ref": "#/$defs/dataResource" } },
    "dataDirectory": { "type": "string" },
    "externalDataSources": { "type": "array", "items": { "$ref": "#/$defs/externalDataSource" } },
    "externalDataSourceRefs": { "type": "array", "items": { "$ref": "#/$defs/externalDataSourceRef" } },
    "startPolicy": { "$ref": "#/$defs/startPolicy" }
  },
  "$defs": {
    "runtime": {
      "type": "object",
      "required": ["protocol"],
      "properties": {
        "protocol": {
          "type": "object",
          "required": ["min", "max"],
          "properties": {
            "min": { "type": "integer" },
            "max": { "type": "integer" }
          }
        },
        "topo": {
          "type": "object",
          "properties": {
            "min": { "type": "string" },
            "max": { "type": "string" }
          }
        }
      }
    },
    "uiHints": {
      "type": "object",
      "properties": {
        "displayName": { "type": "string" },
        "category": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "icon": { "type": "string" },
        "docsUrl": { "type": "string" },
        "order": { "type": "integer" }
      }
    },
    "generator": {
      "type": "object",
      "required": ["insertAfter"],
      "properties": {
        "insertAfter": { "type": "string" },
        "requires": { "type": "array", "items": { "type": "string" } }
      }
    },
    "simulation": {
      "type": "object",
      "properties": {
        "dependencies": { "type": "array", "items": { "type": "string" } },
        "interval_ticks": { "type": "integer", "minimum": 1 },
        "phase_ticks": { "type": "integer", "minimum": 0 },
        "catch_up": { "type": "string", "enum": ["run_once_if_due", "skip_missed"] }
      }
    },
    "invocationScopes": {
      "type": "object",
      "required": ["version"],
      "properties": {
        "version": { "const": 1 },
        "generator": { "$ref": "#/$defs/invocationScope" },
        "simulation": { "$ref": "#/$defs/invocationScope" }
      }
    },
    "invocationScope": {
      "type": "object",
      "required": ["input", "output", "budgets"],
      "properties": {
        "input": {
          "type": "object",
          "required": ["terrainSections", "chunks", "dependencyOverlays", "ownOverlay"],
          "properties": {
            "terrainSections": { "type": "array", "items": { "type": "string", "enum": ["terrain", "climate", "vegetation"] }, "uniqueItems": true },
            "chunks": { "$ref": "#/$defs/chunkSelector" },
            "dependencyOverlays": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
            "ownOverlay": { "type": "boolean" }
          }
        },
        "output": {
          "type": "object",
          "required": ["terrainSections", "chunks", "ownedOverlay", "generatorMetadata"],
          "properties": {
            "terrainSections": { "type": "array", "items": { "type": "string", "enum": ["terrain", "climate", "vegetation"] }, "uniqueItems": true },
            "chunks": { "$ref": "#/$defs/chunkSelector" },
            "ownedOverlay": { "type": "boolean" },
            "generatorMetadata": { "type": "boolean" }
          }
        },
        "budgets": {
          "type": "object",
          "required": ["terrainBytes", "overlayBytes", "outputBytes"],
          "properties": {
            "terrainBytes": { "type": "integer", "minimum": 0 },
            "overlayBytes": { "type": "integer", "minimum": 0 },
            "outputBytes": { "type": "integer", "minimum": 0 }
          }
        }
      }
    },
    "chunkSelector": {
      "oneOf": [
        {
          "type": "object",
          "required": ["type"],
          "properties": { "type": { "const": "all" } }
        },
        {
          "type": "object",
          "required": ["type", "overlays"],
          "properties": {
            "type": { "type": "string", "enum": ["overlay_union", "overlay_intersection"] },
            "overlays": { "type": "array", "items": { "type": "string" }, "minItems": 1, "uniqueItems": true }
          }
        },
        {
          "type": "object",
          "required": ["type"],
          "properties": { "type": { "const": "caller" } }
        }
      ]
    },
    "overlay": {
      "type": "object",
      "required": ["schemaFile"],
      "properties": {
        "schemaFile": { "type": "string" }
      }
    },
    "config": {
      "type": "object",
      "properties": {
        "parameters": { "type": "array", "items": { "$ref": "#/$defs/parameter" } }
      }
    },
    "parameter": {
      "type": "object",
      "required": ["name", "label", "type", "default"],
      "properties": {
        "name": { "type": "string" },
        "label": { "type": "string" },
        "type": { "type": "string", "enum": ["float", "int", "bool"] },
        "default": {},
        "range": { "type": "array", "minItems": 2, "maxItems": 2, "items": {} },
        "tooltip": { "type": "string" }
      }
    },
    "dataResource": {
      "type": "object",
      "required": ["name", "label", "fields", "operations", "keyField"],
      "properties": {
        "schemaVersion": { "type": "integer" },
        "resourceVersion": { "type": "integer" },
        "name": { "type": "string" },
        "label": { "type": "string" },
        "hexBound": { "type": "boolean" },
        "fields": { "type": "array", "items": { "$ref": "#/$defs/dataField" } },
        "operations": { "$ref": "#/$defs/dataOperations" },
        "keyField": { "type": "string" },
        "overlay": { "type": "string" },
        "pagination": { "$ref": "#/$defs/dataPagination" }
      }
    },
    "dataField": {
      "type": "object",
      "required": ["name", "type", "label"],
      "properties": {
        "name": { "type": "string" },
        "type": { "$ref": "#/$defs/dataFieldType" },
        "label": { "type": "string" },
        "editable": { "type": "boolean" },
        "default": {}
      }
    },
    "dataConstructor": {
      "type": "object",
      "required": ["constructor"],
      "properties": {
        "constructor": { "type": "string" },
        "fields": { "type": "array", "items": { "$ref": "#/$defs/dataFieldType" } }
      }
    },
    "dataOperations": {
      "type": "object",
      "properties": {
        "list": { "type": "boolean" },
        "get": { "type": "boolean" },
        "create": { "type": "boolean" },
        "update": { "type": "boolean" },
        "delete": { "type": "boolean" },
        "queryByHex": { "type": "boolean" },
        "queryByField": { "type": "boolean" },
        "sort": { "type": "boolean" },
        "filter": { "type": "boolean" },
        "page": { "type": "boolean" }
      }
    },
    "dataPagination": {
      "type": "object",
      "properties": {
        "defaultPageSize": { "type": "integer" },
        "maxPageSize": { "type": "integer" },
        "defaultPageOffset": { "type": "integer" }
      }
    },
    "startPolicy": {
      "type": "object",
      "properties": {
        "auto_start": { "type": "boolean" },
        "restart_mode": { "type": "string", "enum": ["never", "on_failure", "always"] },
        "max_restarts": { "type": "integer" },
        "restart_window_ms": { "type": "integer" },
        "startup_timeout_ms": { "type": "integer" },
        "request_timeout_ms": { "type": "integer" },
        "shutdown_timeout_ms": { "type": "integer" },
        "backoff_ms": { "type": "integer" }
      }
    },
    "externalDataSource": {
      "type": "object",
      "description": "Provider-owned external source declaration. Migrations, schemas, connection details, and consistency rules are owned by the provider plugin, adapter, or external system; topo may surface status/errors but must not prescribe backend-specific migration tables or schema rules.",
      "required": ["name", "kind", "capabilities", "status"],
      "properties": {
        "name": { "type": "string" },
        "label": { "type": "string" },
        "description": { "type": "string" },
        "kind": { "type": "string" },
        "capabilities": { "type": "array", "items": { "type": "string", "enum": ["query", "mutate", "subscribe", "migrate", "health"] } },
        "resources": { "type": "array", "items": { "type": "string" } },
        "status": { "$ref": "#/$defs/externalStatus" },
        "connection": { "$ref": "#/$defs/opaqueMetadata" },
        "configRefs": { "type": "array", "items": { "$ref": "#/$defs/externalConfigRef" } },
        "grants": { "type": "array", "items": { "$ref": "#/$defs/externalGrant" } },
        "ui": { "$ref": "#/$defs/uiHints" }
      }
    },
    "externalDataSourceRef": {
      "type": "object",
      "description": "Consumer binding to a provider-owned external source. It names desired access and resources without making topo own backend schemas, migrations, connection details, or consistency rules.",
      "required": ["name", "source", "required", "access", "status"],
      "properties": {
        "name": { "type": "string" },
        "provider": { "type": "string" },
        "source": { "type": "string" },
        "required": { "type": "boolean" },
        "access": { "type": "array", "items": { "type": "string", "enum": ["read", "write", "admin"] } },
        "resources": { "type": "array", "items": { "type": "string" } },
        "grant": { "type": "string" },
        "status": { "$ref": "#/$defs/externalStatus" },
        "reference": { "$ref": "#/$defs/opaqueMetadata" },
        "configRefs": { "type": "array", "items": { "$ref": "#/$defs/externalConfigRef" } },
        "ui": { "$ref": "#/$defs/uiHints" }
      }
    },
    "externalGrant": {
      "type": "object",
      "description": "Provider-defined backend-neutral grant. Capabilities and resources scope brokered access but do not prescribe backend migration tables, schemas, or consistency rules.",
      "required": ["name", "access", "capabilities", "status"],
      "properties": {
        "name": { "type": "string" },
        "access": { "type": "array", "items": { "type": "string", "enum": ["read", "write", "admin"] } },
        "capabilities": { "type": "array", "items": { "type": "string", "enum": ["query", "mutate", "subscribe", "migrate", "health"] } },
        "resources": { "type": "array", "items": { "type": "string" } },
        "status": { "$ref": "#/$defs/externalStatus" },
        "reference": { "$ref": "#/$defs/opaqueMetadata" },
        "configRefs": { "type": "array", "items": { "$ref": "#/$defs/externalConfigRef" } }
      }
    },
    "externalConfigRef": {
      "type": "object",
      "description": "Opaque backend-neutral configuration reference for an external source, grant, or consumer binding. The key is supplied by user config, a provider plugin, the environment, or deployment settings; topo preserves it with compatibility metadata but must not interpret it as a backend-specific file layout, schema, migration table, or connection rule.",
      "required": ["name", "origin", "key"],
      "properties": {
        "name": { "type": "string" },
        "origin": { "type": "string", "enum": ["user", "provider", "environment", "deployment"] },
        "key": { "type": "string" },
        "required": { "type": "boolean" },
        "compatibility": { "type": "string" },
        "metadata": { "$ref": "#/$defs/opaqueMetadata" }
      }
    },
    "externalStatus": {
      "type": "object",
      "description": "Provider-declared, backend-neutral status that topo may surface in diagnostics while leaving backend repair, migration, schema, connection, and consistency details to the provider or external system. Optional metadata can identify the provider, availability, health, access mode, capability scope, version/compatibility marker, host observation freshness, and opaque diagnostics without requiring backend-specific settings.",
      "required": ["state"],
      "properties": {
        "state": { "type": "string", "enum": ["unknown", "unconfigured", "ready", "degraded", "unavailable"] },
        "message": { "type": "string" },
        "providerId": { "type": "string" },
        "availability": { "type": "string", "enum": ["unknown", "available", "degraded", "unavailable", "unconfigured"] },
        "health": { "type": "string", "enum": ["unknown", "healthy", "degraded", "unhealthy"] },
        "accessMode": { "type": "string", "enum": ["read_only", "read_write", "admin", "disabled", "provider_managed"] },
        "capabilityScope": { "type": "array", "items": { "type": "string", "enum": ["query", "mutate", "subscribe", "migrate", "health"] } },
        "version": { "type": "string" },
        "compatibility": { "type": "string" },
        "diagnostics": { "$ref": "#/$defs/opaqueMetadata" },
        "observedAt": { "type": "string", "format": "date-time" },
        "fresh": { "type": "boolean" }
      }
    },
    "opaqueMetadata": {
      "type": "object",
      "description": "Opaque provider-owned metadata for handles, bindings, or connection details; topo stores, brokers, and reports it without interpreting a backend, schema, migration table, or consistency rule.",
      "additionalProperties": true
    },
    "dataFieldType": {
      "oneOf": [
        { "type": "string", "enum": ["text", "int", "float", "double", "bool", "fixed2", "fixed3", "fixed4"] },
        {
          "type": "object",
          "properties": {
            "enum": { "type": "array", "items": { "type": "string" } },
            "record": { "type": "array", "items": { "$ref": "#/$defs/dataField" } },
            "adt": { "type": "array", "items": { "$ref": "#/$defs/dataConstructor" } }
          }
        }
      ]
    }
  }
}
